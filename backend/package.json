{
  "name": "regx-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build":        "nest build",
    "start":        "node dist/main",
    "start:dev":    "nest start --watch",
    "start:debug":  "nest start --debug --watch",
    "lint":         "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test":         "jest",
    "test:watch":   "jest --watch",
    "test:cov":     "jest --coverage",
    "test:e2e":     "jest --config ./test/jest-e2e.json",
    "migrate:run":  "ts-node -r tsconfig-paths/register src/database/run-migrations.ts",
    "migrate:create": "ts-node -r tsconfig-paths/register src/database/create-migration.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.2.1",
    "uuid": "^9.0.1",
    "date-fns": "^3.3.0",
    "zod": "^3.22.4",
    "axios": "^1.6.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.1.5",
    "@opentelemetry/sdk-node": "^0.47.0",
    "@opentelemetry/auto-instrumentations-node": "^0.42.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.47.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "nest-winston": "^1.9.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@/(.*)": "<rootDir>/$1",
      "@modules/(.*)": "<rootDir>/modules/$1",
      "@shared/(.*)": "<rootDir>/shared/$1",
      "@config/(.*)": "<rootDir>/config/$1"
    }
  }
}
