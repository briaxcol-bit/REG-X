# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regx
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM_DB=1

# ── JWT (cambia estos valores por strings aleatorios seguros) ─
JWT_ACCESS_SECRET=regx-dev-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=regx-dev-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY=regx-dev-encryption-key-32-chars!

# ── Kong API Gateway ─────────────────────────────────────────
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.placeholder

# ── Storage ──────────────────────────────────────────────────
STORAGE_BUCKET_PRODUCTS=products
STORAGE_BUCKET_RECEIPTS=receipts
STORAGE_BUCKET_LOGOS=logos

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=regx-backend
PROMETHEUS_PORT=9090

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Webhooks ─────────────────────────────────────────────────
WEBHOOK_SECRET=regx-dev-webhook-secret-placeholder

# ── Feature Flags ────────────────────────────────────────────
FF_ELECTRONIC_INVOICE=false
FF_MOBILE_APP=false
FF_AI_FORECASTING=false
FF_MARKETPLACE=true