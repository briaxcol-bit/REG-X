# ============================================================
# REG-X ERP/POS SaaS Enterprise — Environment Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=REG-X
APP_VERSION=1.0.0
APP_PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-token

# ── Database (Direct PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/regx
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM_DB=1

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY=32-char-hex-key-for-aes-256

# ── Kong API Gateway ─────────────────────────────────────────
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxx

# ── Storage ──────────────────────────────────────────────────
STORAGE_BUCKET_PRODUCTS=products
STORAGE_BUCKET_RECEIPTS=receipts
STORAGE_BUCKET_LOGOS=logos

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=regx-backend
PROMETHEUS_PORT=9090

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Webhooks ─────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-signing-secret

# ── Feature Flags ────────────────────────────────────────────
FF_ELECTRONIC_INVOICE=false
FF_MOBILE_APP=false
FF_AI_FORECASTING=false
FF_MARKETPLACE=true
